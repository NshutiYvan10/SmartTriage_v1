# =============================================================================
# SmartTriage backend — environment variables (TEMPLATE)
# =============================================================================
# Copy this file to `.env` and fill in REAL values, OR export these variables
# in your deployment environment. `.env` is gitignored; this `.env.example`
# template is committed so the required variables are documented for whoever
# deploys.
#
# IMPORTANT: Spring Boot does NOT read a `.env` file automatically. Feed these
# in via one of:
#   - Docker Compose:   services.app.env_file: [.env]
#   - Plain shell:      set -a; source .env; set +a; java -jar app.jar
#   - systemd unit:     EnvironmentFile=/etc/smarttriage/smarttriage.env
#   - Kubernetes:       envFrom: [{ secretRef: { name: smarttriage-secrets } }]
#
# Legend:  [REQUIRED] must be set or the app fails to start in that profile.
#          [OPTIONAL] has a safe built-in default; set only to override.
# =============================================================================

# --- Active Spring profile ---------------------------------------------------
# dev (committed default) | staging | prod.
# [REQUIRED in staging/prod] The committed default is 'dev'; you MUST set this
# to 'prod' (or 'staging') for a real deployment, otherwise the app boots with
# dev settings (local DB, the dev-only JWT key, verbose logging).
SPRING_PROFILES_ACTIVE=prod

# --- Database (PostgreSQL) ---------------------------------------------------
# [REQUIRED in staging/prod] No fallback — the app will not start without these.
# (The 'dev' profile ignores them and uses localhost:5432/smarttriage_dev.)
DATABASE_URL=jdbc:postgresql://db-host:5432/smarttriage
DATABASE_USERNAME=smarttriage
DATABASE_PASSWORD=

# --- JWT signing secret ------------------------------------------------------
# [REQUIRED in every non-dev environment] Base64-encoded; must decode to at
# least 32 bytes (256 bits) for HS256, or token signing throws at runtime.
# There is deliberately NO committed fallback (a known signing key lets anyone
# forge tokens for any clinician/role). Generate a fresh one with:
#     openssl rand -base64 48
# (Local dev/test use a clearly-fake dev-only key from application-dev.properties.)
JWT_SECRET=

# --- SMTP / invitation email -------------------------------------------------
# [OPTIONAL] Used only for user-invitation / account-activation emails. The app
# boots and runs clinically WITHOUT these; only those emails are affected (the
# mail check is excluded from /actuator/health for exactly this reason).
# For Gmail, SMTP_PASSWORD must be a 16-char App Password (NOT the account
# password). For production prefer SendGrid / AWS SES / Mailgun.
# SECURITY: never commit a real password here — set it in the environment only.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# --- Frontend URL ------------------------------------------------------------
# [OPTIONAL] Default http://localhost:5173. Used to build the links inside
# invitation/activation emails — set to your real frontend origin in prod.
FRONTEND_URL=https://smarttriage.example.rw
