# ═══════════════════════════════════════════════════════════════════
#  SmartTriage monorepo — .gitattributes
#  Normalises line endings so cross-platform checkouts stay correct.
# ═══════════════════════════════════════════════════════════════════

# Default: let Git handle text files automatically (LF in repo,
# native on checkout) — but override below for files that MUST stay LF.
* text=auto

# Always LF (never CRLF) — breaks if touched on Windows
*.sh           text eol=lf
*.sql          text eol=lf
*.properties   text eol=lf
mvnw           text eol=lf

# Windows-specific — must stay CRLF
*.bat          text eol=crlf
*.cmd          text eol=crlf

# Binary — Git must not touch these
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.pdf          binary
*.jar          binary
*.zip          binary
*.ico          binary
*.woff         binary
*.woff2        binary
*.ttf          binary
*.otf          binary
